@echo off`nsetlocal enabledelayedexpansion`n`necho 🌌 [Oracle System] Starting Unified Setup Protocol...`necho.`n`n:: 1. Check for Bun`nwhere bun >nul 2>nul`nif %errorlevel% neq 0 (`n    echo ❌ [Error] Bun runtime not found. Please install it from https://bun.sh/`n    pause`n    exit /b 1`n)`necho ✅ [Runtime] Bun is available.`necho.`n`n:: 2. Setup Subsystems`nset \"folders=apollo-oracle arra-oracle pulse-cli oracle-skills-cli\"`n`nfor %%f in (%folders%) do (`n    if exist \"C:\Oracle-System\%%f\" (`n        echo 🚀 [Setup] Processing %%f...`n        cd \"C:\Oracle-System\%%f\"`n        if exist \"package.json\" (`n            echo 📦 [Bun] Installing dependencies for %%f...`n            call bun install`n        ) else (`n            echo ⚠️  [Info] No package.json found in %%f, skipping install.`n        )`n        cd ..`n        echo.`n    ) else (`n        echo ❌ [Warning] Subfolder %%f not found.`n    )`n)`n`n:: 3. Setup MCP Config (Optional Recommendation)`necho 🛠️  [Configuration]`necho To use Arra-Oracle via MCP, point your Claude Code/Desktop config to:`necho C:\Oracle-System\arra-oracle-mcp.json`necho.`n`n:: 4. Done`necho ✨ [Oracle System] Setup Complete! All subsystems are ready.`necho.`nPause
