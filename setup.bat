@echo off`nsetlocal enabledelayedexpansion`n`necho 🌌 [Oracle System] Starting Unified Setup Protocol...`necho.`n`n:: 1. Check for Bun`nwhere bun >nul 2>nul`nif %errorlevel% neq 0 (`n    echo ❌ [Error] Bun runtime not found. Please install it from https://bun.sh/`n    pause`n    exit /b 1`n)`necho ✅ [Runtime] Bun is available.`necho.`n`n:: 2. Check for Claude CLI (The Key Master)`nwhere claude >nul 2>nul`nif %errorlevel% neq 0 (`n    echo ⚠️  [Warning] Claude CLI not found.`n    echo    To use Oracle System with your existing Claude keys, please run:`n    echo    npm install -g @anthropic-ai/claude-code`n    echo    Then run \"claude auth login\" to sync your keys.`n) else (`n    echo ✅ [Auth] Claude CLI is available.`n)`necho.`n`n:: 3. Setup Subsystems`nset \"folders=apollo-oracle arra-oracle pulse-cli oracle-skills-cli\"`n`nfor %%f in (%folders%) do (`n    if exist \"%~dp0%%f\" (`n        echo 🚀 [Setup] Processing %%f...`n        cd /d \"%~dp0%%f\"`n        if exist \"package.json\" (`n            echo 📦 [Bun] Installing dependencies for %%f...`n            call bun install`n            `n            :: Special Case for Arra-Oracle (Database Setup)`n            if \"%%f\"==\"arra-oracle\" (`n                echo 🗄️  [DB] Initializing Database for Arra...`n                call bunx drizzle-kit push`n            )`n        ) else (`n            echo ⚠️  [Info] No package.json found in %%f, skipping install.`n        )`n        cd /d \"%~dp0\"`n        echo.`n    ) else (`n        echo ❌ [Warning] Subfolder %%f not found.`n    )`n)`n`n:: 4. MCP Configuration`necho 🛠️  [Configuration]`necho To use Arra-Oracle via MCP, point your Claude Code/Desktop config to:`necho %~dp0arra-oracle-mcp.json`necho.`n`n:: 5. Done`necho ✨ [Oracle System] Setup Complete! Everything is ready to roll.`necho.`nPause
